{
  "name": "@lxmf/react-native",
  "version": "0.1.0",
  "description": "LXMF Reticulum mesh networking for React Native + Expo",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "default": "./build/index.js"
    },
    "./package.json": "./package.json"
  },
  "expo": {
    "plugin": "./app.plugin.js"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf build",
    "prepare": "npm run build",
    "prepublishOnly": "npm run clean && npm run build",
    "pack:check": "npm pack --dry-run",
    "test": "jest",
    "lint": "eslint src",
    "type-check": "tsc --noEmit",
    "rust:android": "bash ../scripts/build-rust-android.sh",
    "rust:ios": "bash ../scripts/build-rust-ios.sh",
    "build:android": "npm run rust:android && npm run build",
    "build:ios": "npm run rust:ios && npm run build",
    "build:all": "npm run rust:android && npm run rust:ios && npm run build"
  },
  "keywords": [
    "lxmf",
    "reticulum",
    "mesh",
    "networking",
    "ble",
    "react-native",
    "expo"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/anon0mesh/lxmf_react_native_rust.git"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "expo": "*",
    "expo-modules-core": "*",
    "react": "*",
    "react-native": "*"
  },
  "dependencies": {
    "@expo/config-plugins": "^9.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-native": "^0.72.0",
    "expo-modules-core": "^1.12.26",
    "typescript": "^5.0.0"
  },
  "files": [
    "build",
    "ios",
    "android",
    "LxmfReactNative.podspec",
    "expo-module.config.json",
    "app.plugin.js",
    "expo-module.config.js",
    "README.md"
  ]
}
